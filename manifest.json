{
  "manifest_version": 3,
  "name": "Moon Rider Webcam Controller (skeleton)",
  "version": "0.1.0",
  "description": "Inject webcam hand-tracking as controller input for Moon Rider (Punch Mode skeleton).",
  "permissions": [],
  "host_permissions": [
    "https://supermedium.com/*",
    "https://moonrider.xyz/*",
    "https://*.moonrider.xyz/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Start / stop Moon Rider webcam control" },
  "content_scripts": [
    {
      "matches": ["https://supermedium.com/moonrider/*", "https://moonrider.xyz/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://supermedium.com/moonrider/*", "https://moonrider.xyz/*"],
      "js": ["content-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "offscreen.html"],
      "matches": ["https://supermedium.com/*", "https://moonrider.xyz/*"]
    }
  ]
}
